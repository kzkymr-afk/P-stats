// 手順:
// 1. このファイルを複製して同じフォルダに `P-statsSecrets.xcconfig` として保存する（gitignore 済み）
// 2. 下の YOUR_KEY_HERE を Google Cloud の API キーに置き換える（引用符は不要）
// 3. Xcode でクリーンビルド
//
// CI ではリポジトリに置かず、ビルド前にこの内容を生成するか、
// `xcodebuild GOOGLE_PLACES_API_KEY="実キー" ...` のようにビルド設定で渡す。

GOOGLE_PLACES_API_KEY = YOUR_KEY_HERE
