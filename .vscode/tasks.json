{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Pachi Collector 実行",
      "type": "shell",
      "command": "python3",
      "args": ["${workspaceFolder}/scraper/Pachi_Collector.py"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      }
    },
    {
      "label": "マスターCSV→JSON変換",
      "type": "shell",
      "command": "python3",
      "args": [
        "${workspaceFolder}/scripts/convert_master_one_sheet.py",
        "${workspaceFolder}/master_out/master_one_sheet.csv"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
